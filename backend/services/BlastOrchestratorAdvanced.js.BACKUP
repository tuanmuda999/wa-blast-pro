import SessionManager from './SessionManager.js';
import { 
    ANTI_DETECTION_CONFIG,
    ProxyManager,
    MessageRandomizer,
    HumanBehavior 
} from '../config/anti-detection.js';
import { HttpsProxyAgent } from 'https-proxy-agent';

class AdvancedBlastOrchestrator {
    constructor(db, io) {
        this.db = db;
        this.io = io;
        this.sessions = new Map();
        this.proxyManager = null;
        this.messageCache = new Map();
        this.successRate = 1.0;
        this.currentRateLimit = ANTI_DETECTION_CONFIG.RATE_LIMITS.perHour.aggressive;
        
        // Initialize proxy manager if proxies configured
        this.initProxyManager();
    }

    initProxyManager() {
        const allProxies = [
            ...ANTI_DETECTION_CONFIG.PROXY.pools.residential,
            ...ANTI_DETECTION_CONFIG.PROXY.pools.datacenter,
            ...ANTI_DETECTION_CONFIG.PROXY.pools.mobile
        ];

        if (allProxies.length > 0) {
            this.proxyManager = new ProxyManager(allProxies);
            console.log(`🔒 Proxy manager initialized with ${allProxies.length} proxies`);
        }
    }

    // ==================== SESSION MANAGEMENT ====================
    async addSession(sessionId, proxyUrl = null) {
        if (this.sessions.has(sessionId)) {
            throw new Error('Session already exists');
        }

        console.log(`➕ Adding session: ${sessionId}`);
        
        // Select proxy
        const proxy = proxyUrl || (this.proxyManager ? this.proxyManager.getNext() : null);
        
        const session = new SessionManager(sessionId, this.db, this.io, {
            proxy,
            userAgent: this.generateUserAgent(),
            deviceSpoof: ANTI_DETECTION_CONFIG.DEVICE_SPOOFING.enabled
        });
        
        this.sessions.set(sessionId, session);
        
        // Warm up session if enabled
        if (ANTI_DETECTION_CONFIG.SESSION_WARMING.enabled) {
            await HumanBehavior.sessionWarmup(session);
        }
        
        return session;
    }

    getSession(sessionId) {
        // First try internal sessions map
        if (this.sessions.has(sessionId)) {
            return this.sessions.get(sessionId);
        }
        
        // Fallback to global orchestrator if exists
        if (global.orchestrator && global.orchestrator !== this) {
            return global.orchestrator.getSession(sessionId);
        }
        
        return null;
    }

    generateUserAgent() {
        const devices = ANTI_DETECTION_CONFIG.DEVICE_SPOOFING.realistic.popularDevices;
        const device = devices[Math.floor(Math.random() * devices.length)];
        
        return `WhatsApp/2.23.20 Android/${device}`;
    }

    // ==================== MODE 1: SAFE MODE (95% success, ~120 msg/hr) ====================
    async blastSafeMode(sessionId, contacts, message, options = {}) {
        console.log(`🛡️ SAFE MODE BLAST`);
        console.log(`   Target: ${contacts.length} contacts`);
        console.log(`   Rate: ~120 msg/hr, 95% success expected`);
        
        const session = this.getSession(sessionId);
        if (!session || !session.isConnected()) {
            throw new Error('Session not available');
        }

        // Generate message variations
        const messageVariations = MessageRandomizer.generateVariations(message, 10);
        const results = [];
        let messageCount = 0;

        for (const contact of contacts) {
            try {
                // Pick random message variation
                const msgVariation = messageVariations[
                    Math.floor(Math.random() * messageVariations.length)
                ];

                // Human typing simulation (2-4 seconds)
                await HumanBehavior.simulateTyping(msgVariation);

                // Random thinking pause (1-2 seconds)
                await new Promise(resolve => setTimeout(resolve, 1000 + Math.random() * 1000));

                // Send message
                const recipient = contact.number + '@s.whatsapp.net';
                await session.sock.sendMessage(recipient, {
                    text: msgVariation
                });

                // Log success
                try {
                    this.db.db.prepare(`
                        INSERT INTO message_logs (session_id, recipient, message, status, sent_at)
                        VALUES (?, ?, ?, 'sent', datetime('now'))
                    `).run(sessionId, contact.number, msgVariation);
                } catch (logErr) {
                    console.error('Log error:', logErr.message);
                }

                results.push({ number: contact.number, status: 'sent' });
                messageCount++;

                console.log(`✅ [${messageCount}/${contacts.length}] Sent to ${contact.number}`);

                // SAFE MODE DELAY: 8-15 seconds
                const baseDelay = 8000 + Math.random() * 7000;
                await new Promise(resolve => setTimeout(resolve, baseDelay));

                // BREAK EVERY 15 MESSAGES: 2-5 minutes
                if (messageCount % 15 === 0 && messageCount < contacts.length) {
                    const breakTime = 120000 + Math.random() * 180000; // 2-5 min
                    console.log(`☕ Safe mode break: ${Math.round(breakTime / 1000)}s`);
                    await new Promise(resolve => setTimeout(resolve, breakTime));
                    console.log(`✅ Break complete, resuming...`);
                }

            } catch (err) {
                console.error(`❌ Failed to ${contact.number}:`, err.message);
                
                try {
                    this.db.db.prepare(`
                        INSERT INTO message_logs (session_id, recipient, message, status, sent_at)
                        VALUES (?, ?, ?, 'failed', datetime('now'))
                    `).run(sessionId, contact.number, message);
                } catch (logErr) {
                    console.error('Log error:', logErr.message);
                }

                results.push({ number: contact.number, status: 'failed', error: err.message });
            }
        }

        const successCount = results.filter(r => r.status === 'sent').length;
        const failedCount = results.filter(r => r.status === 'failed').length;

        console.log(`✅ SAFE MODE COMPLETED`);
        console.log(`   Success: ${successCount}/${contacts.length}`);
        console.log(`   Success Rate: ${(successCount / contacts.length * 100).toFixed(1)}%`);

        return {
            mode: 'safe',
            total: contacts.length,
            success: successCount,
            failed: failedCount,
            results
        };
    }

    // ==================== MODE 2: BALANCED MODE (90% success, ~150 msg/hr) ====================
    async blastBalancedMode(sessionId, contacts, message, options = {}) {
        console.log(`⚖️ BALANCED MODE BLAST`);
        console.log(`   Target: ${contacts.length} contacts`);
        console.log(`   Rate: ~150 msg/hr, 90% success expected`);
        
        const session = this.getSession(sessionId);
        if (!session || !session.isConnected()) {
            throw new Error('Session not available');
        }

        const messageVariations = MessageRandomizer.generateVariations(message, 15);
        const results = [];
        let messageCount = 0;

        for (const contact of contacts) {
            try {
                const msgVariation = messageVariations[
                    Math.floor(Math.random() * messageVariations.length)
                ];

                // Lighter typing simulation (1-2 seconds)
                await HumanBehavior.simulateTyping(msgVariation);

                // Send message
                const recipient = contact.number + '@s.whatsapp.net';
                await session.sock.sendMessage(recipient, {
                    text: msgVariation
                });

                try {
                    this.db.db.prepare(`
                        INSERT INTO message_logs (session_id, recipient, message, status, sent_at)
                        VALUES (?, ?, ?, 'sent', datetime('now'))
                    `).run(sessionId, contact.number, msgVariation);
                } catch (logErr) {
                    console.error('Log error:', logErr.message);
                }

                results.push({ number: contact.number, status: 'sent' });
                messageCount++;

                console.log(`✅ [${messageCount}/${contacts.length}] Sent to ${contact.number}`);

                // BALANCED DELAY: 5-10 seconds
                const baseDelay = 5000 + Math.random() * 5000;
                await new Promise(resolve => setTimeout(resolve, baseDelay));

                // BREAK EVERY 20 MESSAGES: 1-3 minutes
                if (messageCount % 20 === 0 && messageCount < contacts.length) {
                    const breakTime = 60000 + Math.random() * 120000; // 1-3 min
                    console.log(`☕ Balanced mode break: ${Math.round(breakTime / 1000)}s`);
                    await new Promise(resolve => setTimeout(resolve, breakTime));
                    console.log(`✅ Break complete, resuming...`);
                }

            } catch (err) {
                console.error(`❌ Failed to ${contact.number}:`, err.message);
                
                try {
                    this.db.db.prepare(`
                        INSERT INTO message_logs (session_id, recipient, message, status, sent_at)
                        VALUES (?, ?, ?, 'failed', datetime('now'))
                    `).run(sessionId, contact.number, message);
                } catch (logErr) {
                    console.error('Log error:', logErr.message);
                }

                results.push({ number: contact.number, status: 'failed', error: err.message });
            }
        }

        const successCount = results.filter(r => r.status === 'sent').length;
        const failedCount = results.filter(r => r.status === 'failed').length;

        console.log(`✅ BALANCED MODE COMPLETED`);
        console.log(`   Success: ${successCount}/${contacts.length}`);

        return {
            mode: 'balanced',
            total: contacts.length,
            success: successCount,
            failed: failedCount,
            results
        };
    }

    // ==================== MODE 3: FAST MODE (85% success, ~200 msg/hr) ====================
    async blastFastMode(sessionId, contacts, message, options = {}) {
        console.log(`⚡ FAST MODE BLAST`);
        console.log(`   Target: ${contacts.length} contacts`);
        console.log(`   Rate: ~200 msg/hr, 85% success expected`);
        
        const session = this.getSession(sessionId);
        if (!session || !session.isConnected()) {
            throw new Error('Session not available');
        }

        const messageVariations = MessageRandomizer.generateVariations(message, 20);
        const results = [];
        let messageCount = 0;

        for (const contact of contacts) {
            try {
                const msgVariation = messageVariations[
                    Math.floor(Math.random() * messageVariations.length)
                ];

                // Minimal typing simulation (500ms)
                await new Promise(resolve => setTimeout(resolve, 500));

                // Send message
                const recipient = contact.number + '@s.whatsapp.net';
                await session.sock.sendMessage(recipient, {
                    text: msgVariation
                });

                try {
                    this.db.db.prepare(`
                        INSERT INTO message_logs (session_id, recipient, message, status, sent_at)
                        VALUES (?, ?, ?, 'sent', datetime('now'))
                    `).run(sessionId, contact.number, msgVariation);
                } catch (logErr) {
                    console.error('Log error:', logErr.message);
                }

                results.push({ number: contact.number, status: 'sent' });
                messageCount++;

                console.log(`✅ [${messageCount}/${contacts.length}] Sent to ${contact.number}`);

                // FAST DELAY: 2-5 seconds
                const baseDelay = 2000 + Math.random() * 3000;
                await new Promise(resolve => setTimeout(resolve, baseDelay));

                // BREAK EVERY 30 MESSAGES: 30-60 seconds
                if (messageCount % 30 === 0 && messageCount < contacts.length) {
                    const breakTime = 30000 + Math.random() * 30000; // 30-60 sec
                    console.log(`☕ Fast mode break: ${Math.round(breakTime / 1000)}s`);
                    await new Promise(resolve => setTimeout(resolve, breakTime));
                    console.log(`✅ Break complete, resuming...`);
                }

            } catch (err) {
                console.error(`❌ Failed to ${contact.number}:`, err.message);
                
                try {
                    this.db.db.prepare(`
                        INSERT INTO message_logs (session_id, recipient, message, status, sent_at)
                        VALUES (?, ?, ?, 'failed', datetime('now'))
                    `).run(sessionId, contact.number, message);
                } catch (logErr) {
                    console.error('Log error:', logErr.message);
                }

                results.push({ number: contact.number, status: 'failed', error: err.message });
            }
        }

        const successCount = results.filter(r => r.status === 'sent').length;
        const failedCount = results.filter(r => r.status === 'failed').length;

        console.log(`✅ FAST MODE COMPLETED`);
        console.log(`   Success: ${successCount}/${contacts.length}`);

        return {
            mode: 'fast',
            total: contacts.length,
            success: successCount,
            failed: failedCount,
            results
        };
    }

    // ==================== MODE 4: INSTANT MODE (60% success, ~800 msg/hr) ====================
    async blastInstantMode(sessionId, contacts, message, options = {}) {
        console.log(`🚀 INSTANT MODE BLAST`);
        console.log(`   Target: ${contacts.length} contacts`);
        console.log(`   Rate: ~800 msg/hr, 60% success expected`);
        console.log(`   ⚠️ HIGH RISK - No breaks, minimal delays`);
        
        const session = this.getSession(sessionId);
        if (!session || !session.isConnected()) {
            throw new Error('Session not available');
        }

        const messageVariations = MessageRandomizer.generateVariations(message, 5);
        const results = [];
        let messageCount = 0;

        for (const contact of contacts) {
            try {
                const msgVariation = messageVariations[
                    Math.floor(Math.random() * messageVariations.length)
                ];

                // Send message
                const recipient = contact.number + '@s.whatsapp.net';
                await session.sock.sendMessage(recipient, {
                    text: msgVariation
                });

                try {
                    this.db.db.prepare(`
                        INSERT INTO message_logs (session_id, recipient, message, status, sent_at)
                        VALUES (?, ?, ?, 'sent', datetime('now'))
                    `).run(sessionId, contact.number, msgVariation);
                } catch (logErr) {
                    console.error('Log error:', logErr.message);
                }

                results.push({ number: contact.number, status: 'sent' });
                messageCount++;

                console.log(`✅ [${messageCount}/${contacts.length}] Sent to ${contact.number}`);

                // INSTANT DELAY: 100-500ms only
                const baseDelay = 100 + Math.random() * 400;
                await new Promise(resolve => setTimeout(resolve, baseDelay));

                // NO BREAKS in instant mode!

            } catch (err) {
                console.error(`❌ Failed to ${contact.number}:`, err.message);
                
                try {
                    this.db.db.prepare(`
                        INSERT INTO message_logs (session_id, recipient, message, status, sent_at)
                        VALUES (?, ?, ?, 'failed', datetime('now'))
                    `).run(sessionId, contact.number, message);
                } catch (logErr) {
                    console.error('Log error:', logErr.message);
                }

                results.push({ number: contact.number, status: 'failed', error: err.message });
            }
        }

        const successCount = results.filter(r => r.status === 'sent').length;
        const failedCount = results.filter(r => r.status === 'failed').length;

        console.log(`✅ INSTANT MODE COMPLETED`);
        console.log(`   Success: ${successCount}/${contacts.length}`);
        console.log(`   Success Rate: ${(successCount / contacts.length * 100).toFixed(1)}%`);

        return {
            mode: 'instant',
            total: contacts.length,
            success: successCount,
            failed: failedCount,
            results
        };
    }

    // ==================== MODE 5: STEALTH INSTANT (70-80% success) ====================
    async blastStealthInstant(sessionId, contacts, message, options = {}) {
        console.log(`⚫ STEALTH INSTANT MODE`);
        console.log(`   Target: ${contacts.length} contacts`);
        console.log(`   Using advanced evasion + message variations`);
        console.log(`   Expected: 70-80% success rate`);
        
        const session = this.getSession(sessionId);
        if (!session || !session.isConnected()) {
            throw new Error('Session not available');
        }

        // Generate MORE variations for stealth
        const messageVariations = MessageRandomizer.generateVariations(message, 20);

        const sendPromises = contacts.map(async (contact, index) => {
            // Micro-delays (50-200ms) to avoid perfect simultaneity
            const microDelay = 50 + Math.random() * 150;
            await new Promise(resolve => setTimeout(resolve, microDelay * index));

            const msgVariation = messageVariations[
                Math.floor(Math.random() * messageVariations.length)
            ];

            const recipient = contact.number + '@s.whatsapp.net';

            try {
                await session.sock.sendMessage(recipient, {
                    text: msgVariation
                });

                // Log success
                try {
                    this.db.db.prepare(`
                        INSERT INTO message_logs (session_id, recipient, message, status, sent_at)
                        VALUES (?, ?, ?, 'sent', datetime('now'))
                    `).run(sessionId, contact.number, msgVariation);
                } catch (logErr) {
                    console.error('Log error:', logErr.message);
                }

                return { number: contact.number, status: 'sent' };

            } catch (err) {
                // Log failure
                try {
                    this.db.db.prepare(`
                        INSERT INTO message_logs (session_id, recipient, message, status, sent_at)
                        VALUES (?, ?, ?, 'failed', datetime('now'))
                    `).run(sessionId, contact.number, message);
                } catch (logErr) {
                    console.error('Log error:', logErr.message);
                }

                return { number: contact.number, status: 'failed', error: err.message };
            }
        });

        const results = await Promise.all(sendPromises);
        const successCount = results.filter(r => r.status === 'sent').length;

        console.log(`⚫ STEALTH INSTANT COMPLETED`);
        console.log(`   Success: ${successCount}/${contacts.length}`);
        console.log(`   Success Rate: ${(successCount / contacts.length * 100).toFixed(1)}%`);
        
        return {
            mode: 'stealth-instant',
            total: contacts.length,
            success: successCount,
            failed: contacts.length - successCount,
            results
        };
    }

    // ==================== LEGACY METHOD (BACKWARD COMPATIBILITY) ====================
    async sendBlastAdvanced(sessionId, listId, message, options = {}) {
        console.log(`🚀 ADVANCED BLAST (LEGACY METHOD)`);
        console.log(`   Forwarding to Safe Mode...`);
        
        // Get contacts from listId
        const contacts = this.db.db.prepare(
            'SELECT number FROM contacts WHERE list_id = ?'
        ).all(listId);

        if (!contacts || contacts.length === 0) {
            throw new Error('No contacts found');
        }

        // Forward to safe mode
        return await this.blastSafeMode(sessionId, contacts, message, options);
    }

    // ==================== LEGACY METHOD (BACKWARD COMPATIBILITY) ====================
    async sendStealthInstant(sessionId, listId, message) {
        console.log(`⚫ STEALTH INSTANT (LEGACY METHOD)`);
        console.log(`   Forwarding to blastStealthInstant...`);
        
        // Get contacts from listId
        const contacts = this.db.db.prepare(
            'SELECT number FROM contacts WHERE list_id = ?'
        ).all(listId);

        if (!contacts || contacts.length === 0) {
            throw new Error('No contacts found');
        }

        // Forward to stealth instant blast
        return await this.blastStealthInstant(sessionId, contacts, message);
    }

    // ==================== UTILITY METHODS ====================
    
    getAllSessions() {
        return Array.from(this.sessions.values());
    }

    async removeSession(sessionId) {
        const session = this.sessions.get(sessionId);
        if (!session) {
            throw new Error('Session not found');
        }

        await session.cleanup();
        this.sessions.delete(sessionId);
        console.log(`🗑️ Advanced session removed: ${sessionId}`);
    }

    async cleanup() {
        console.log('🧹 Cleaning up advanced orchestrator sessions...');
        const cleanupPromises = Array.from(this.sessions.values()).map(s => s.cleanup());
        await Promise.all(cleanupPromises);
        this.sessions.clear();
    }
}

export default AdvancedBlastOrchestrator;